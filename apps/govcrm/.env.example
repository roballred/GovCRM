# Copy to .env.local (never committed).
# Runtime pool — MUST be a non-superuser role (superusers bypass RLS; the seed
# creates govcrm_app with the grants).
DATABASE_URL=postgresql://govcrm_app:govcrm-app-dev@127.0.0.1:5432/govcrm_dev
# Auth pool — owner/privileged URL used ONLY by createAuth: the login lookup
# runs before an org context exists, and govcore.users RLS requires the GUC.
AUTH_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/govcrm_dev
AUTH_SECRET=generate-with--openssl-rand--base64-32
AUTH_TRUST_HOST=true
# Seed/migrate use the owner URL:
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/govcrm_dev pnpm seed
